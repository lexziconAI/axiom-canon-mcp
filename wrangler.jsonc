{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "axiom-canon-mcp",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-01",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"observability": { "enabled": true },
	"upload_source_maps": true,

	// ── CONFIG: the canon SOURCE (swap to the ratified canon's real home later = config-only, no rebuild) ──
	// PROOF source = a clearly-marked v1.0 COPY in this repo's canon-source/. NOT the canonical home,
	// NOT the un-ratified v1.1 candidate. GITHUB_TOKEN is a SECRET (private repo) — `wrangler secret put`,
	// never here, never inlined. For local dev it lives in .dev.vars (gitignored).
	"vars": {
		"CANON_SOURCE_REPO": "lexziconAI/axiom-canon-mcp",
		"CANON_SOURCE_PATH": "canon-source/COLONY_CANON.md",
		"CANON_SOURCE_REF": "master",
		"ALLOWED_ORIGIN": "https://claude.ai",
		"MAX_HEARTBEAT_AGE_SECONDS": "14400"
	},

	// ── Heartbeat re-attestation (DOC-3.7 fix: last-VERIFIED, not commit-age) ──
	// A cron re-fetches the live canon source, re-hashes the ACTUAL bytes, and writes
	// a SIGNED verified_at marker to KV. A read is verified-live only if a valid,
	// recent (<= MAX_HEARTBEAT_AGE_SECONDS) heartbeat attests the SAME bytes served now.
	// A dead heartbeat goes dark within the ceiling (4h). HEARTBEAT_SECRET = SECRET
	// (HMAC signing key + /__attest admin bearer): `wrangler secret put HEARTBEAT_SECRET`.
	"kv_namespaces": [
		{ "binding": "HEARTBEAT_KV", "id": "779cb9744c054794a9e8bce2172870bd" }
	],
	"triggers": {
		"crons": ["*/30 * * * *"]
	}
}
